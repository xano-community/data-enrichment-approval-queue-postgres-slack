# Environment variables for the Enterprise Data Enrichment and Approval Queue module.
# Set these in your Xano workspace (Settings -> Environment Variables). These names must match exactly.

# Connection string for the external Postgres source database (read by POST /records/import).
POSTGRES_CONNECTION_STRING=

# Generic REST enrichment provider. The module calls POST {ENRICHMENT_API_BASE_URL}/enrich
# with an "Authorization: Bearer {ENRICHMENT_API_KEY}" header. See the README's
# "Required enrichment API contract" for the exact request/response shape.
ENRICHMENT_API_KEY=
ENRICHMENT_API_BASE_URL=

# Slack Incoming Webhook URL. needs_review records POST { "text": "..." } here.
SLACK_WEBHOOK_URL=

# Shared secret required on every endpoint via the api_secret field.
API_AUTH_SECRET=
